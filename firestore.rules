rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function user() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isTeacher() {
      return signedIn() && user().role == "teacher";
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update: if isOwner(uid) || isTeacher();
    }

    match /classes/{classId} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher() && request.resource.data.teacherUid == request.auth.uid;
      match /students/{studentId} {
        allow read: if signedIn();
        allow create, update: if signedIn();
      }
    }

    match /invites/{code} {
      allow read: if true;
      allow create, update, delete: if isTeacher() && request.resource.data.teacherUid == request.auth.uid;
    }

    match /studentIds/{studentId} {
      allow read: if true;
      allow create, update: if signedIn();
    }

    match /apps/{appId} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher() && request.resource.data.teacherUid == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher() && request.resource.data.teacherUid == request.auth.uid;
    }

    match /replies/{replyId} {
      allow read: if isTeacher();
      allow create: if signedIn();
    }

    match /surveyResponses/{responseId} {
      allow read: if isTeacher();
      allow create, update: if signedIn();
    }

    match /usageLogs/{logId} {
      allow read: if isTeacher();
      allow create: if signedIn();
    }

    match /printAssignments/{assignmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher() && request.resource.data.teacherUid == request.auth.uid;
    }

    match /printSubmissions/{submissionId} {
      allow read: if isTeacher();
      allow create, update: if signedIn();
    }
  }
}
